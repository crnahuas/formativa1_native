    {
      "name": "00 - Seguridad y roles",
      "description": "Capturas para demostrar 401 sin token, 403 con rol insuficiente y 201 con rol INSTRUCTOR.",
      "item": [
        {
          "name": "00.1 EC2 sin token debe responder 401",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
