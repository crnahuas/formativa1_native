                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{ec2Url}}/cursos",
            "description": "Capturar que el rol ESTUDIANTE puede consultar cursos."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('estudianteToken')) { throw new Error('Falta estudianteToken'); }"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 con token ESTUDIANTE', function () { pm.response.to.have.status(200); });"
