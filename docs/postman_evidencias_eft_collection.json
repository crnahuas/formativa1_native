                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{rabbitPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{rabbitUrl}}/api/queues/%2F/{{queueName}}",
            "description": "Capturar cola resumen.inscripcion.queue con messages listo para consumo."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('RabbitMQ cola visible', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "pm.test('Nombre de cola correcto', function () { pm.expect(data.name).to.eql(pm.collectionVariables.get('queueName')); });"
                ]
              }
            }
          ]
        },
