                  "pm.test('Resumen disponible', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "03.2 Producir mensaje RabbitMQ",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{instructorToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": "{{ec2Url}}/inscripciones/{{numeroResumen}}/resumenes-mq/producir",
            "description": "Capturar 200 con cola, exchange y routing key."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Mensaje publicado', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "pm.test('Datos RabbitMQ presentes', function () {",
                  "  pm.expect(data.cola).to.exist;",
                  "  pm.expect(data.exchange).to.exist;",
                  "  pm.expect(data.routingKey).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "03.3 RabbitMQ Management - detalle cola",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
