{
  "info": {
    "name": "CDY2204 Semana 4 - Video API Gateway + Azure AD B2C",
    "description": "Coleccion preparada para grabar el video de Semana 4. Flujo sugerido: preparar datos en EC2, demostrar bloqueo 401 sin token en API Gateway y luego ejecutar endpoints protegidos con JWT emitido por Azure AD B2C.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "apiGatewayUrl",
      "value": "https://f3k22g500d.execute-api.us-east-1.amazonaws.com",
      "description": "URL base publica de AWS API Gateway."
    },
    {
      "key": "ec2BackendUrl",
      "value": "http://107.23.174.145:8080",
      "description": "URL directa del backend Spring Boot en EC2, usada solo como control."
    },
    {
      "key": "accessToken",
      "value": "",
      "description": "Pegar aqui el JWT obtenido desde Azure AD B2C antes de ejecutar las requests protegidas."
    },
    {
      "key": "cursoId",
      "value": "1",
      "description": "Se actualiza automaticamente al crear el curso demo."
    },
    {
      "key": "numeroResumen",
      "value": "1",
      "description": "Se actualiza automaticamente al crear la inscripcion demo."
    }
  ],
  "item": [
    {
      "name": "00 - Preparacion de datos en EC2",
      "description": "Usar esta carpeta al inicio del video para comprobar que el backend esta vivo y generar un numeroResumen nuevo para las pruebas protegidas.",
      "item": [
        {
          "name": "00.1 EC2 - Listar cursos",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{ec2BackendUrl}}/cursos",
            "description": "Control rapido para confirmar que el backend Spring Boot esta respondiendo directamente en EC2."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('EC2 responde 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('La respuesta es un arreglo', function () {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "00.2 EC2 - Crear curso demo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Semana 4 API Gateway Demo\",\n  \"instructor\": \"Docente CDY2204\",\n  \"duracion\": \"24 horas\",\n  \"costo\": 120000\n}"
            },
            "url": "{{ec2BackendUrl}}/cursos",
            "description": "Crea un curso nuevo para usarlo en la inscripcion demo. La prueba guarda automaticamente el id en la variable cursoId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Curso creado con 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('La respuesta contiene id de curso', function () {",
                  "  pm.expect(data.id).to.exist;",
                  "});",
                  "pm.collectionVariables.set('cursoId', String(data.id));",
                  "console.log('cursoId guardado:', data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "00.3 EC2 - Crear inscripcion demo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estudianteNombre\": \"Estudiante Demo Semana 4\",\n  \"estudianteEmail\": \"demo.semana4@duocuc.cl\",\n  \"cursoIds\": [{{cursoId}}]\n}"
            },
            "url": "{{ec2BackendUrl}}/inscripciones",
            "description": "Crea una inscripcion para obtener un numeroResumen valido. La prueba guarda inscripcionId como numeroResumen."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Inscripcion creada con 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('La respuesta contiene inscripcionId', function () {",
                  "  pm.expect(data.inscripcionId).to.exist;",
                  "});",
                  "pm.test('La respuesta contiene totalPagar', function () {",
                  "  pm.expect(data.totalPagar).to.exist;",
                  "});",
                  "pm.collectionVariables.set('numeroResumen', String(data.inscripcionId));",
                  "console.log('numeroResumen guardado:', data.inscripcionId);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - API Gateway sin token",
      "description": "Evidencia de seguridad: estas requests deben responder 401 Unauthorized porque no envian JWT.",
      "item": [
        {
          "name": "01.1 Bloqueo JWT - Descargar resumen S3 sin token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{apiGatewayUrl}}/s3/downloadResumen?numeroResumen={{numeroResumen}}",
            "description": "Demuestra que API Gateway bloquea una ruta real de S3 cuando no se envia token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sin token responde 401 Unauthorized', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "pm.test('La respuesta indica Unauthorized', function () {",
                  "  pm.expect(pm.response.text()).to.include('Unauthorized');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "01.2 Bloqueo JWT - Resumen local sin token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{apiGatewayUrl}}/inscripciones/{{numeroResumen}}/resumen",
            "description": "Segunda evidencia de bloqueo, usando una ruta con parametro de path."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sin token responde 401 Unauthorized', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - API Gateway con token Azure AD B2C",
      "description": "Antes de ejecutar esta carpeta, pegar el JWT de Azure AD B2C en la variable accessToken.",
      "item": [
        {
          "name": "02.1 Descargar resumen generado por Spring Boot",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{apiGatewayUrl}}/inscripciones/{{numeroResumen}}/resumen",
            "description": "Genera y descarga el archivo fisico resumen.txt usando API Gateway con JWT valido."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Antes de ejecutar esta request, pega el JWT de Azure AD B2C en la variable accessToken.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Respuesta contiene resumen correcto', function () {",
                  "  pm.expect(pm.response.text()).to.include('Resumen de inscripcion');",
                  "  pm.expect(pm.response.text()).to.include('Numero resumen: ' + pm.collectionVariables.get('numeroResumen'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "02.2 S3 - Subir resumen",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": "{{apiGatewayUrl}}/s3/uploadResumen?numeroResumen={{numeroResumen}}",
            "description": "Sube a S3 el resumen generado. La clave esperada es numeroResumen/resumen.txt."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Clave S3 correcta', function () {",
                  "  pm.expect(data.clave).to.eql(pm.collectionVariables.get('numeroResumen') + '/resumen.txt');",
                  "});",
                  "pm.test('Respuesta indica subida', function () {",
                  "  pm.expect(data.mensaje).to.include('subido');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "02.3 S3 - Actualizar resumen",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [],
            "url": "{{apiGatewayUrl}}/s3/updateResumen?numeroResumen={{numeroResumen}}",
            "description": "Actualiza el resumen existente en S3 usando API Gateway protegido por JWT."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Clave S3 correcta', function () {",
                  "  pm.expect(data.clave).to.eql(pm.collectionVariables.get('numeroResumen') + '/resumen.txt');",
                  "});",
                  "pm.test('Respuesta indica actualizacion', function () {",
                  "  pm.expect(data.mensaje).to.include('actualizado');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "02.4 S3 - Descargar resumen",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{apiGatewayUrl}}/s3/downloadResumen?numeroResumen={{numeroResumen}}",
            "description": "Descarga desde S3 el archivo resumen.txt pasando por API Gateway con JWT."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Respuesta contiene resumen descargado desde S3', function () {",
                  "  pm.expect(pm.response.text()).to.include('Resumen de inscripcion');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Cierre de evidencia",
      "description": "Ejecutar al final del video para dejar limpia la evidencia de S3.",
      "item": [
        {
          "name": "03.1 S3 - Eliminar resumen",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{apiGatewayUrl}}/s3/deleteResumen?numeroResumen={{numeroResumen}}",
            "description": "Elimina desde S3 el resumen usado en el video. Ejecutar al final."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Clave S3 correcta', function () {",
                  "  pm.expect(data.clave).to.eql(pm.collectionVariables.get('numeroResumen') + '/resumen.txt');",
                  "});",
                  "pm.test('Respuesta indica eliminacion', function () {",
                  "  pm.expect(data.mensaje).to.include('eliminado');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
