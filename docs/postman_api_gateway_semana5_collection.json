                  "const data = pm.response.json();",
                  "pm.test('Clave S3 correcta', function () { pm.expect(data.clave).to.eql(pm.collectionVariables.get('numeroResumen') + '/resumen.txt'); });",
                  "pm.test('Respuesta indica subida', function () { pm.expect(data.mensaje).to.include('subido'); });"
                ]
              }
