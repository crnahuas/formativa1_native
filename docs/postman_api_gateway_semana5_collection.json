    },
    {
      "name": "02 - API Gateway con token Azure AD B2C",
      "description": "Evidencia funcional sobre el API Gateway e IDaaS reutilizados de Semana 4: los endpoints inscritos funcionan cuando se envia un JWT valido.",
      "item": [
        {
          "name": "02.1 Cursos - Listar",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{apiGatewayUrl}}/cursos",
            "description": "Lista cursos mediante API Gateway con JWT valido."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('La respuesta es un arreglo', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "02.2 Cursos - Crear",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{apiGatewayUrl}}/cursos",
            "description": "Crea un curso mediante API Gateway y guarda cursoId.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Semana 5 API Gateway Demo\",\n  \"instructor\": \"Docente CDY2204\",\n  \"duracion\": \"24 horas\",\n  \"costo\": 120000\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Curso creado con 201 Created', function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "pm.test('La respuesta contiene id de curso', function () { pm.expect(data.id).to.exist; });",
                  "pm.collectionVariables.set('cursoId', String(data.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "02.3 Inscripciones - Crear",
          "request": {
            "auth": {
              "type": "bearer",
