              "mode": "raw",
              "raw": "{\n  \"estudianteNombre\": \"Estudiante Demo Semana 5\",\n  \"estudianteEmail\": \"demo.semana5@duocuc.cl\",\n  \"cursoIds\": [{{cursoId}}]\n}"
