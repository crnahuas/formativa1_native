{
  "info": {
    "name": "CDY2204 Semana 5 - Reutilizacion Semana 4 + Spring Security",
    "description": "Coleccion para evidenciar Semana 5 reutilizando la configuracion de Semana 4. Primero valida que el backend Spring Boot desplegado en EC2 quede securitizado con Spring Security y responda 401 sin JWT. Luego prueba los endpoints reutilizando el API Gateway y Azure AD B2C configurados en Semana 4.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "apiGatewayUrl",
      "value": "https://f3k22g500d.execute-api.us-east-1.amazonaws.com",
      "description": "URL base publica de AWS API Gateway."
    },
    {
      "key": "ec2BackendUrl",
      "value": "http://107.23.174.145:8080",
      "description": "IP elastica o URL directa del backend Spring Boot en EC2. Se usa para evidenciar que Spring Security bloquea llamadas directas sin JWT."
    },
    {
      "key": "accessToken",
      "value": "",
      "description": "JWT emitido por Azure AD B2C. Debe coincidir con el issuer configurado en AZURE_B2C_ISSUER_URI."
    },
    {
      "key": "cursoId",
      "value": "1",
      "description": "Se actualiza automaticamente al crear el curso demo por API Gateway."
    },
    {
      "key": "numeroResumen",
      "value": "1",
      "description": "Se actualiza automaticamente al crear la inscripcion demo por API Gateway."
    }
  ],
  "item": [
    {
      "name": "00 - Backend EC2 securitizado sin token",
      "description": "Paso de la guia Semana 5: despues de redesplegar el backend modificado, llamar la IP elastica de EC2 y comprobar que Spring Security bloquea el acceso directo sin JWT.",
      "item": [
        {
          "name": "00.1 EC2 - Listar cursos sin token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{ec2BackendUrl}}/cursos",
            "description": "Debe responder 401 porque Spring Security protege el microservicio incluso antes de pasar por API Gateway."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Backend EC2 securitizado responde 401 Unauthorized', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "00.2 EC2 - Descargar resumen sin token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{ec2BackendUrl}}/inscripciones/{{numeroResumen}}/resumen",
            "description": "Segunda evidencia directa contra EC2 para mostrar que los endpoints del backend quedaron securitizados."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Backend EC2 securitizado responde 401 Unauthorized', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
