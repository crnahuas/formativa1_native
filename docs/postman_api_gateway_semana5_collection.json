              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Inscripcion creada con 201 Created', function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "pm.test('La respuesta contiene id de inscripcion', function () { pm.expect(data.id).to.exist; });",
                  "pm.collectionVariables.set('numeroResumen', String(data.id));"
                ]
              }
            }
          ]
        },
